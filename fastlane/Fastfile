# Workaround: new apps have no AppStoreReviewDetail yet → fetch returns "No data"
require 'deliver'
module DeliverReviewDetailPatch
  def review_attachment_file(version)
    super
  rescue RuntimeError => e
    raise unless e.message.include?("No data")
  end
end
Deliver::UploadMetadata.prepend(DeliverReviewDetailPatch)

default_platform(:ios)

platform :ios do
  desc "앱 개인정보 추적 설정 수정 (추적 없음으로 변경)"
  lane :fix_privacy do
    app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
    app_id = "6763474658"

    # 현재 데이터 사용 항목 조회
    client = Spaceship::ConnectAPI
    usages = client.get_app_data_usages(app_id: app_id)
    UI.message("현재 데이터 사용 항목: #{usages.count}개")

    usages.each do |usage|
      UI.message("삭제 중: #{usage.id}")
      client.delete_app_data_usage(app_data_usage_id: usage.id)
    end

    # 가용 카테고리/목적 조회
    categories = client.get_app_data_usage_categories
    purposes = client.get_app_data_usage_purposes
    protections = client.get_app_data_usage_data_protections rescue []

    UI.message("Categories: #{categories.map { |c| "#{c.id}: #{c.attributes}" }}")
    UI.message("Purposes: #{purposes.map { |p| "#{p.id}: #{p.attributes}" }}")
  end

  desc "App Store Connect에 앱 등록 (최초 1회)"
  lane :create_app do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
    produce(
      app_identifier: "com.cykintel.remember",
      app_name: "외워줘",
      language: "ko",
      app_version: "1.0.0",
      sku: "com.cykintel.remember",
      team_id: ENV["TEAM_ID"],
      itc_team_id: ENV["ITC_TEAM_ID"],
      skip_devcenter: true
    )
  end

  desc "TestFlight 업로드 (심사 제출 없음)"
  lane :beta do |options|
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
    ipa_path = options[:ipa] || Dir.glob("build-*.ipa").max_by { |f| File.mtime(f) }
    upload_to_testflight(
      api_key: api_key,
      ipa: ipa_path,
      skip_waiting_for_build_processing: true
    )
  end

  desc "스크린샷만 업로드"
  lane :upload_screenshots do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      submit_for_review: false,
      force: true,
      skip_binary_upload: true,
      skip_metadata: true,
      run_precheck_before_submit: false,
      screenshots_path: "./fastlane/screenshots",
      metadata_path: "./fastlane/metadata/ios",
      overwrite_screenshots: true,
      verbose: true
    )
  end

  desc "App Store 메타데이터 + 바이너리 업로드 (심사 제출 없음)"
  lane :prepare_release do
    api_key = app_store_connect_api_key(
      key_id: ENV["APP_STORE_CONNECT_API_KEY_ID"],
      issuer_id: ENV["APP_STORE_CONNECT_API_ISSUER_ID"],
      key_filepath: ENV["APP_STORE_CONNECT_API_KEY_PATH"]
    )
    deliver(
      api_key: api_key,
      submit_for_review: false,
      force: true,
      skip_binary_upload: true,
      skip_screenshots: false,
      overwrite_screenshots: true,
      run_precheck_before_submit: false,
      metadata_path: "./fastlane/metadata/ios",
      screenshots_path: "./fastlane/screenshots",
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end
end

platform :android do
  desc "Google Play에 앱 등록 (최초 1회 — AAB 직접 업로드 후 콘솔에서 앱 생성 필요)"
  lane :create_app do
    UI.message("Google Play는 API로 신규 앱 생성을 지원하지 않습니다.")
    UI.message("Play Console(https://play.google.com/console)에서 수동으로 앱을 생성한 뒤,")
    UI.message("첫 AAB를 내부 테스트 트랙에 직접 업로드해 앱을 활성화하세요.")
    UI.message("이후 fastlane android prepare_release 를 사용할 수 있습니다.")
  end

  desc "메타데이터만 업로드 (바이너리 없음)"
  lane :upload_metadata do
    supply(
      package_name: "com.cykintel.remember",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_FILE"],
      skip_upload_apk: true,
      skip_upload_aab: true,
      skip_upload_images: false,
      skip_upload_screenshots: false,
      metadata_path: "./fastlane/metadata/android"
    )
  end

  desc "Play Store AAB 업로드 (내부 트랙 Draft, 심사 제출 없음)"
  lane :prepare_release do |options|
    aab_path = options[:aab] || Dir.glob("*.aab").max_by { |f| File.mtime(f) }
    UI.user_error!("AAB 파일을 찾을 수 없습니다. aab: 옵션으로 경로를 지정하세요.") unless aab_path && File.exist?(aab_path.to_s)
    supply(
      package_name: "com.cykintel.remember",
      json_key: ENV["GOOGLE_PLAY_JSON_KEY_FILE"],
      aab: aab_path,
      track: "internal",
      release_status: "draft",
      metadata_path: "./fastlane/metadata/android"
    )
  end
end
