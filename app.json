{
  "expo": {
    "name": "외워줘",
    "slug": "remember",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#4F46E5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.cykintel.remember",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "맞춤형 광고 제공을 위해 광고 식별자를 사용합니다. 거부해도 앱의 모든 기능을 이용할 수 있습니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#4F46E5"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.cykintel.remember"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#4F46E5"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-6220210021054377~7478368090",
          "iosAppId": "ca-app-pub-6220210021054377~1104531430"
        }
      ],
      "expo-tracking-transparency"
    ],
    "scheme": "remember",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fd37408d-601b-4098-9ab1-3f37d4a5c39e"
      }
    },
    "owner": "chriskim84"
  }
}
